generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model ai_predictions {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id          String    @db.Uuid
  overdue_risk     Float?
  predicted_status String?   @db.VarChar(50)
  recommendation   String?
  model_used       String?   @db.VarChar(100)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  tasks            tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_prediction_task")
}

model notifications {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiver_id String    @db.Uuid
  title       String    @db.VarChar(255)
  message     String?
  is_read     Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users     @relation(fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_receiver")
}

model task_progress {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id    String    @db.Uuid
  progress   Int?
  note       String?
  updated_by String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamp(6)
  tasks      tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_progress_task")
  users      users?    @relation(fields: [updated_by], references: [id], onUpdate: NoAction, map: "fk_progress_user")
}

model tasks {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  team_id    String @db.Uuid
  project_id String @db.Uuid

  title       String  @db.VarChar(255)
  description String?
  assignee_id String? @db.Uuid
  created_by  String  @db.Uuid

  priority String?    @default("medium") @db.VarChar(20)
  status   TaskStatus @default(TODO)
  progress Int?       @default(0)

  deadline        DateTime? @db.Timestamp(6)
  estimated_hours Int?

  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  ai_predictions ai_predictions[]
  task_progress  task_progress[]
  task_comments  task_comments[]
  subtasks       subtasks[]

  task_attachments task_attachments[]
  users_tasks_assignee_idTousers users? @relation("tasks_assignee_idTousers", fields: [assignee_id], references: [id], onUpdate: NoAction, map: "fk_assignee")

  users_tasks_created_byTousers users @relation("tasks_created_byTousers", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_creator")

  teams teams @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task_team")

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model team_members {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  team_id   String    @db.Uuid
  user_id   String    @db.Uuid
  role      String?   @default("member") @db.VarChar(20)
  joined_at DateTime? @default(now()) @db.Timestamp(6)
  teams     teams     @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_team")
  users     users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@unique([team_id, user_id])
}

model teams {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String         @db.VarChar(100)
  slug         String         @unique @db.VarChar(120)
  description  String?
  avatar_url   String?
  owner_id     String         @db.Uuid
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  updated_at   DateTime?      @default(now()) @db.Timestamp(6)
  tasks        tasks[]
  team_members team_members[]
  projects     projects[]
  invites      team_invites[]
  users        users          @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_owner")
}

model projects {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  team_id String @db.Uuid

  name        String  @db.VarChar(255)
  description String?

  status ProjectStatus @default(PLANNING)

  start_date DateTime? @db.Timestamp(6)
  end_date   DateTime? @db.Timestamp(6)

  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  teams teams @relation(fields: [team_id], references: [id], onDelete: Cascade)

  tasks tasks[]

  @@index([team_id])
}

model users {
  id       String @id @db.Uuid
  email    String @unique @db.VarChar(100)
  username String @unique @db.VarChar(50)

  full_name String? @db.VarChar(100)
  avatar    String?

  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  notifications                  notifications[]
  task_progress                  task_progress[]
  tasks_tasks_assignee_idTousers tasks[]         @relation("tasks_assignee_idTousers")
  tasks_tasks_created_byTousers  tasks[]         @relation("tasks_created_byTousers")
  team_members                   team_members[]
  teams                          teams[]
  task_comments                  task_comments[]
}

model task_comments {
  id         String   @id @default(uuid()) @db.Uuid

  task_id    String   @db.Uuid
  user_id    String   @db.Uuid

  content    String

  parent_id  String?  @db.Uuid  

  created_at DateTime @default(now())

  tasks tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)
  users users @relation(fields: [user_id], references: [id])

  parent task_comments? @relation("CommentReplies", fields: [parent_id], references: [id])
  replies task_comments[] @relation("CommentReplies")
}

model subtasks {
  id String @id @default(uuid()) @db.Uuid

  task_id String @db.Uuid

  title String

  completed Boolean @default(false)

  created_at DateTime @default(now())

  tasks tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)
}
model task_attachments {
  id         String   @id @default(uuid()) @db.Uuid
  task_id    String   @db.Uuid
  file_name  String
  file_url   String
  file_type  String?
  size       Int?
  uploaded_by String? @db.Uuid
  created_at DateTime @default(now())

  tasks tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)
}
model team_invites {
  id          String   @id @default(uuid()) @db.Uuid
  team_id     String   @db.Uuid
  email       String   @db.VarChar(255)
  token       String   @unique
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | EXPIRED

  invited_by  String   @db.Uuid
  expires_at  DateTime

  created_at  DateTime @default(now())

  teams teams @relation(fields: [team_id], references: [id], onDelete: Cascade)
}