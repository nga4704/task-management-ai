{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "ES2020",

    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"]
}